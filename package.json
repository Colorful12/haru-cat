{
  "name": "haru-cat",
  "version": "0.0.1",
  "description": "A React component for adding a tiny cat to your website.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "taki",
    "url": "https://x.com/taki73_cat"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "LICENSE.ja.md",
    "LICENSE-CODE.md",
    "LICENSE-ASSETS.md",
    "LICENSE-ASSETS.ja.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Colorful12/haru-cat.git"
  },
  "homepage": "https://github.com/Colorful12/haru-cat#readme",
  "bugs": {
    "url": "https://github.com/Colorful12/haru-cat/issues"
  },
  "keywords": [
    "react",
    "component",
    "cat",
    "mascot"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p tsconfig.lib.json",
    "lint": "eslint .",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
